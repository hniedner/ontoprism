		"lint": "eslint .",
		"fallow": "node scripts/fallow-gate.mjs",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test:coverage": "vitest run --coverage",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
