# Copy to .env for local development. Defaults point at the services already running
# on this dev machine.

# Ontology SPARQL stores (Oxigraph)
NCIT_SPARQL_URL=http://localhost:7878
UBERON_SPARQL_URL=http://localhost:7879

# Pinned NCIt build the role/version guard tests assert against. This is the
# owl:versionInfo the LIVE store actually reports (verified 2026-07-03); the
# assessment mislabeled it 26.05d, but the loaded inferred build is 26.02d.
NCIT_EXPECTED_VERSION=26.02d

# PostgreSQL (concept cache, decomposition run state, provenance)
DATABASE_URL=postgresql+asyncpg://ontoprism:ontoprism@localhost:5432/ontoprism
