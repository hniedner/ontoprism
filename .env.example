# Copy to .env for local development. Defaults point at ontoprism's OWN isolated
# services (docker-compose.yml), distinct from the sibling fairdata app so both run
# with no interference.

# Ontology SPARQL stores (ontoprism's Oxigraph containers)
NCIT_SPARQL_URL=http://localhost:7888
UBERON_SPARQL_URL=http://localhost:7889

# Pinned NCIt build the role/version guard tests assert against (the live store's
# owl:versionInfo; the assessment mislabeled it 26.05d).
NCIT_EXPECTED_VERSION=26.02d

# caDSR CDE repository (ontoprism-owned CoW clone)
CADSR_DB_PATH=data/cadsr/cde_repository.db

# PostgreSQL (ontoprism-owned; refresh provenance + future concept cache)
DATABASE_URL=postgresql+asyncpg://ontoprism:ontoprism@localhost:5433/ontoprism
