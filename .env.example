# Copy to .env for local development. Defaults point at ontoprism's OWN isolated
# services (docker-compose.yml), distinct from the sibling fairdata app so both run
# with no interference.

# Ontology SPARQL stores (ontoprism's Oxigraph containers)
NCIT_SPARQL_URL=http://localhost:7888
UBERON_SPARQL_URL=http://localhost:7889

# Pinned NCIt build the role/version guard tests assert against (the live store's
# owl:versionInfo; the assessment mislabeled it 26.05d).
NCIT_EXPECTED_VERSION=26.02d

# caDSR CDE repository (ontoprism-owned CoW clone)
CADSR_DB_PATH=data/cadsr/cde_repository.db

# PostgreSQL (ontoprism-owned; refresh provenance + future concept cache)
DATABASE_URL=postgresql+asyncpg://ontoprism:ontoprism@localhost:5433/ontoprism

# Authorization for the mutating endpoints (refresh / reload / download). Unset or
# empty = open (dev); set to require an X-API-Key header on those endpoints.
# API_KEY=

# Per-client-IP rate limit (fixed window / minute) on all endpoints; 0 disables it.
RATE_LIMIT_PER_MINUTE=600

# NCIt OWL refresh: NCI EVS download base + managed download dir (inside the reload
# allowlist so a downloaded OWL can then be loaded) + transfer retry count.
NCIT_OWL_BASE_URL=https://evs.nci.nih.gov/ftp1/NCI_Thesaurus
NCIT_OWL_DIR=data/ncit-owl
NCIT_OWL_MAX_RETRIES=3

# caDSR CDE refresh: source URL of the released CDE XML zip (served over HTTPS from the
# caDSR host's /ftp/ path) + managed cache dir + retries. The download is metadata-cached
# and offline-tolerant (serves the cached copy when the source is unreachable).
CADSR_DOWNLOAD_URL=https://cadsr.nci.nih.gov/ftp/caDSR_Downloads/CDE/XML/releasedCDEsXML-OD.zip
CADSR_DATA_DIR=data/cadsr
CADSR_DOWNLOAD_MAX_RETRIES=3
